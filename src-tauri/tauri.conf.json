{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Color Ticket Simulator",
  "version": "0.1.0",
  "identifier": "com.codex.color-ticket-simulator",
  "build": {
    "beforeDevCommand": "npm.cmd run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm.cmd run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Color Ticket Simulator",
        "width": 1440,
        "height": 930,
        "minWidth": 1180,
        "minHeight": 760,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
